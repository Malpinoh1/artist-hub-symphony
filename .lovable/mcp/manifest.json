{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://hewyffhdykietximpfbu.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "malpinohdistro-mcp",
      "version": "0.1.0",
      "title": "MALPINOHDISTRO"
    },
    "tools": [
      {
        "name": "list_my_releases",
        "title": "List my releases",
        "description": "List releases owned by the signed-in artist, most recent first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max rows to return (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "status": {
              "description": "Optional status filter (e.g. pending, approved, live, rejected).",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_release",
        "title": "Get release details",
        "description": "Fetch full details for a release the caller can access, including its tracks.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "release_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Release UUID."
            }
          },
          "required": [
            "release_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "get_my_earnings",
        "title": "Get my earnings summary",
        "description": "Return the signed-in artist's wallet balance, total earnings, available balance and recent monthly earnings.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "months": {
              "description": "How many recent months to include (default 12).",
              "type": "integer",
              "minimum": 1,
              "maximum": 36
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_my_withdrawals",
        "title": "List my withdrawals",
        "description": "List the signed-in artist's withdrawal requests, most recent first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max rows to return (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "status": {
              "description": "Optional status filter (PENDING, APPROVED, COMPLETED, REJECTED).",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_my_profile",
        "title": "Get my profile",
        "description": "Return the signed-in user's profile, role list, and linked artist record.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_my_transactions",
        "title": "List my income transactions",
        "description": "List the signed-in artist's income/royalty ledger transactions, most recent first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max rows to return (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
